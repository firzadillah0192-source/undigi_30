<IfModule mod_rewrite.c>
  RewriteEngine On

  # Force HTTPS in production. Comment this block for local HTTP testing.
  RewriteCond %{HTTPS} !=on
  RewriteCond %{HTTP:X-Forwarded-Proto} !https
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Route /api and /api/... through the API front controller.
  RewriteRule ^api/?$ api/index.php [L,QSA]
  RewriteRule ^api/(.*)$ api/index.php [L,QSA]
</IfModule>

<IfModule mod_headers.c>
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Block direct access to private application folders.
RedirectMatch 403 ^/(data|includes)(/.*)?$

# Block root PHP files except intentional entry points under /api.
<FilesMatch "^.*\.php$">
  Require all denied
</FilesMatch>

<Directory "api">
  <FilesMatch "^index\.php$">
    Require all granted
  </FilesMatch>
</Directory>

# Keep dotfiles private.
<FilesMatch "^\.">
  Require all denied
</FilesMatch>
